{
  "name": "agent-loop-runner",
  "version": "1.0.0",
  "description": "CLI utilities for agent automation loops — starting with PR babysitting via the Cursor SDK.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "babysit-pr": "tsx src/babysit-pr.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "babysit-pr": "./src/babysit-pr.ts"
  },
  "keywords": [
    "cursor",
    "ai-agent",
    "github",
    "cli",
    "pr-automation",
    "typescript"
  ],
  "author": "TonkaToyXL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TonkaToyXL/agent-loop-runner.git"
  },
  "bugs": {
    "url": "https://github.com/TonkaToyXL/agent-loop-runner/issues"
  },
  "homepage": "https://github.com/TonkaToyXL/agent-loop-runner#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.18"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
